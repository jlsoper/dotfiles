#  $HOME/.bash_pkg


##########  /etc/yum.repos.d/*.repo



 pkg-history() { dnf history info "$@" ; }
 pkg-info() { if [ -n "$1" ]; then dnf info "$1" ; else echo "usage: $FUNCNAME <package>" ; fi }
 pkg-list-installed() { rpm -qa | sort ; }
 pkg-listfiles() { if [ -n "$1" ]; then dnf repoquery -l "$1" ; else echo "usage: $FUNCNAME <package>" ; fi }
 pkg-repolist() { dnf repolist ; }
 pkg-search() { if [ -n "$1" ]; then dnf list "$1" ; else echo "usage: $FUNCNAME <package>" ; fi }


